<Window
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Windows Setup"
    Height="1080" Width="1920"
    WindowStyle="None" 
    WindowState="Maximized"
    ResizeMode="NoResize"
    Topmost="True"
    ShowInTaskbar="False">
    
    <Grid>
        <!-- Background Image -->
        <Grid.Background>
            <ImageBrush x:Name="BackgroundImage" 
                        Stretch="UniformToFill"/>
        </Grid.Background>
        
        <!-- Dark Overlay -->
        <Rectangle Fill="#88000000"/>
        
        <StackPanel Margin="80,40,80,40">
            <!-- Header -->
            <TextBlock x:Name="HeaderText"
                       Text="Configuring your device" 
                       Foreground="White" 
                       FontFamily="Segoe UI Light"
                       FontSize="46" 
                       Margin="0,0,0,20"/>
            
            <!-- Status -->
            <TextBlock x:Name="StatusText"
                       Text="" 
                       Foreground="#FFB3B3B3"
                       FontFamily="Segoe UI"
                       FontSize="20" 
                       Margin="0,0,0,10"/>

            <!-- Selection Panel -->
            <StackPanel x:Name="SelectionPanel" 
                        Margin="0,20,0,0">
                
                <!-- Country/Region -->
                <TextBlock Text="Country/Region" 
                           Foreground="White"
                           FontFamily="Segoe UI"
                           FontSize="16" 
                           Margin="0,0,0,8"/>
                <ComboBox x:Name="CountrySelector"
                          FontFamily="Segoe UI"
                          FontSize="16"
                          Margin="0,0,0,20"
                          Width="400"
                          HorizontalAlignment="Left">
                    <ComboBoxItem Content="Germany" Tag="DE"/>
                    <ComboBoxItem Content="Poland" Tag="PL"/>
                    <ComboBoxItem Content="Sweden" Tag="SE"/>
                    <ComboBoxItem Content="United States" Tag="US"/>
                </ComboBox>

                <!-- Persona Selection -->
                <TextBlock Text="Device type" 
                           Foreground="White"
                           FontFamily="Segoe UI"
                           FontSize="16" 
                           Margin="0,0,0,8"/>
                <ComboBox x:Name="PersonaSelector"
                          FontFamily="Segoe UI"
                          FontSize="16"
                          Margin="0,0,0,20"
                          Width="400"
                          HorizontalAlignment="Left">
                    <ComboBoxItem Content="Standard" Tag="ST"/>
                    <ComboBoxItem Content="Shared" Tag="SH"/>
                    <ComboBoxItem Content="Batch" Tag="BT"/>
                </ComboBox>

                <!-- Language -->
                <TextBlock Text="Language" 
                           Foreground="White"
                           FontFamily="Segoe UI"
                           FontSize="16" 
                           Margin="0,0,0,8"/>
                <ComboBox x:Name="LanguageSelector"
                          FontFamily="Segoe UI"
                          FontSize="16"
                          Margin="0,0,0,20"
                          Width="400"
                          HorizontalAlignment="Left">
                    <ComboBoxItem Content="German" Tag="de-de"/>
                    <ComboBoxItem Content="English" Tag="en-us"/>
                    <ComboBoxItem Content="Polish" Tag="pl-pl"/>
                    <ComboBoxItem Content="Swedish" Tag="sv-se"/>
                </ComboBox>

                <!-- Continue Button -->
                <Button x:Name="ContinueButton"
                        Content="Continue"
                        FontFamily="Segoe UI"
                        FontSize="16"
                        Width="120"
                        Height="36"
                        HorizontalAlignment="Left"
                        Margin="0,20,0,0"
                        Background="#FF0078D4"
                        Foreground="White"
                        BorderThickness="0">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Style.Triggers>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Opacity" Value="0.5"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <!-- Exit Button (Hidden by default) -->
                <Button x:Name="ExitButton"
                        Content="Exit"
                        FontFamily="Segoe UI"
                        FontSize="16"
                        Width="120"
                        Height="36"
                        HorizontalAlignment="Left"
                        Margin="0,20,0,0"
                        Background="#FFE81123"
                        Foreground="White"
                        BorderThickness="0"
                        Visibility="Collapsed">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#FFF1707A"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>

            <!-- Progress Grid -->
            <Grid x:Name="ProgressGrid" 
                  Margin="0,40,0,0" 
                  HorizontalAlignment="Left"
                  Visibility="Collapsed">
                <!-- Remove both the Canvas element with spinner and the TextBlock -->
                <!-- No content needed inside this Grid anymore, just keep the empty Grid container -->
            </Grid>
        </StackPanel>

        <!-- Add Thomas logo to bottom right corner -->
        <Image x:Name="LogoImage" 
               Width="180" 
               Height="60"
               HorizontalAlignment="Right" 
               VerticalAlignment="Bottom"
               Margin="0,0,20,20"
               Stretch="Uniform" />

        <!-- Move the Technical View button out of the SelectionPanel and into the main Grid -->
        <!-- Add this right before the closing </Grid> tag at the end of the file -->

        <Button x:Name="TechnicalViewButton"
                Content="Technical View"
                FontFamily="Segoe UI"
                FontSize="16"
                Width="120"
                Height="36"
                HorizontalAlignment="Right"
                VerticalAlignment="Bottom"
                Margin="0,0,210,20"
                Background="#FF333333"
                Foreground="White"
                BorderThickness="0">
            <Button.Style>
                <Style TargetType="Button">
                    <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#FF555555"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </Button.Style>
        </Button>
    </Grid>
</Window> 